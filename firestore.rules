rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ---------------------------------------------------------
    // Global Safety Net
    // ---------------------------------------------------------
    match /{document=**} {
      allow read, write: if false;
    }

    // ---------------------------------------------------------
    // Global Helpers
    // ---------------------------------------------------------
    function isSignedIn() { return request.auth != null; }
    
    // Hardened isAdmin check:
    // 1. Checks if user UID is in 'admins' collection
    // 2. BOOTSTRAP: Allows ali.islam.officials@gmail.com to be the first admin
    function isAdmin() { 
      return isSignedIn() && (
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) || 
        (request.auth.token.email == 'ali.islam.officials@gmail.com' && request.auth.token.email_verified == true)
      ); 
    }
    
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function serverTime() { return request.time; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }

    // ---------------------------------------------------------
    // Products Collection
    // ---------------------------------------------------------
    match /products/{productId} {
      allow read: if true;
      allow create: if isAdmin() && isValidProduct(incoming());
      allow update: if isAdmin() && isValidProduct(incoming());
      allow delete: if isAdmin();
      
      function isValidProduct(data) {
        let required = ['name', 'price', 'category', 'images', 'sku', 'createdAt', 'updatedAt'];
        return data.keys().hasAll(required)
          && data.name is string && data.name.size() <= 200
          && data.price is number && data.price >= 0
          && data.category is string
          && data.images is list
          && data.sku is string
          && data.createdAt is timestamp
          && data.updatedAt is timestamp
          && (!('oldPrice' in data) || data.oldPrice is number)
          && (!('stock' in data) || data.stock is number)
          && (!('isFeatured' in data) || data.isFeatured is bool)
          && (!('isTrending' in data) || data.isTrending is bool)
          && (!('description' in data) || data.description is string);
      }
    }

    // ---------------------------------------------------------
    // Orders Collection
    // ---------------------------------------------------------
    match /orders/{orderId} {
      allow create: if isValidOrder(incoming());
      allow read, update, delete: if isAdmin();

      function isValidOrder(data) {
        let required = ['customer', 'items', 'totalAmount', 'status', 'createdAt'];
        let custReq = ['name', 'email', 'phone', 'address'];
        return data.keys().hasAll(required)
          && data.customer.keys().hasAll(custReq)
          && data.status == 'pending'
          && data.totalAmount is number && data.totalAmount >= 0
          && data.createdAt is timestamp
          && data.customer.name is string && data.customer.name.size() > 0
          && data.customer.email is string && data.customer.email.size() > 0
          && data.customer.phone is string && data.customer.phone.size() >= 8
          && data.customer.address is string && data.customer.address.size() > 0
          && data.items is list && data.items.size() > 0;
      }
    }

    // ---------------------------------------------------------
    // Settings Collection
    // ---------------------------------------------------------
    match /settings/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ---------------------------------------------------------
    // Categories/Other helpers
    // ---------------------------------------------------------
    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /admins/{adminId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
  }
}
